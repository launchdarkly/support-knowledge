{
  "name": "hello-react-native-expo",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "android-release": "expo run:android --variant release",
    "ios": "expo start --ios",
    "clean-reset": "yarn cache clean && rm -rf node_modules && rm -rf .expo && rm -rf yarn.lock",
    "watchman-reset": "watchman watch-del-all && watchman shutdown-server"
  },
  "dependencies": {
    "@launchdarkly/observability-react-native": "latest",
    "@launchdarkly/react-native-client-sdk": "latest",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/cli-server-api": "^17.0.0",
    "expo": "^57.0.7",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-dotenv": "^3.4.11"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@types/react": "~19.2.4",
    "@types/react-native-dotenv": "^0.2.2",
    "typescript": "^7.0.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "@babel/core",
        "typescript"
      ]
    }
  },
  "private": true,
  "packageManager": "yarn@3.4.1"
}
